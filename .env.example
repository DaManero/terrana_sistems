# ─────────────────────────────────────────────
#  TERRANA — Variables de entorno
#  Copiar este archivo como .env y completar los valores reales.
#  NUNCA commitear el archivo .env
# ─────────────────────────────────────────────

# Base de datos
DATABASE_URL=postgresql://terrana_user:terrana_pass@localhost:5432/terrana

# Autenticación
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Email transaccional
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@terrana.com

# MercadoPago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# URLs de los servicios
BACKEND_URL=http://localhost:4000
ECOMMERCE_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Entorno
NODE_ENV=development

# Puerto del backend
PORT=4000
