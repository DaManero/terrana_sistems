{
    "name": "terrana-backend",
    "version": "1.0.0",
    "description": "API REST centralizada de Terrana",
    "main": "dist/server.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "db:migrate": "npx prisma migrate dev",
        "db:deploy": "npx prisma migrate deploy",
        "db:studio": "npx prisma studio",
        "db:generate": "npx prisma generate",
        "db:seed": "ts-node prisma/seed.ts",
        "db:seed:prod": "ts-node prisma/seed.prod.ts"
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-validator": "^7.2.1",
        "helmet": "^8.0.0",
        "jsonwebtoken": "^9.0.2",
        "mercadopago": "^2.0.15",
        "morgan": "^1.10.0",
        "nodemailer": "^8.0.1",
        "resend": "^6.9.4",
        "uuid": "^11.1.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/morgan": "^1.9.9",
        "@types/node": "^22.13.9",
        "@types/nodemailer": "^6.4.17",
        "@types/uuid": "^10.0.0",
        "prisma": "^5.22.0",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.8.2"
    },
    "engines": {
        "node": ">=20"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    }
}
